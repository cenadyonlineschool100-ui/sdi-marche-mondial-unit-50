# ============================================
# CONFIGURATION EXAMPLE - SDI STORE PRODUCTION
# ============================================
# Copier ce fichier en .env et remplir avec vos valeurs
# cp .env.example .env

# SÉCURITÉ - MODIFIER SELON VOTRE ENVIRONNEMENT
DJANGO_SECRET_KEY=your-secure-random-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# APRÈS DÉPLOIEMENT - Ajouter votre domaine:
# ALLOWED_HOSTS=localhost,127.0.0.1,votredomaine.com,www.votredomaine.com
# CSRF_TRUSTED_ORIGINS=https://votredomaine.com,https://www.votredomaine.com

# API KEYS
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# BASE DE DONNÉES (OPTIONNEL - Docker gère par défaut)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379

# EMAIL - OPTIONNEL (Configurer si vous avez un serveur SMTP)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=votre.email@gmail.com
# EMAIL_HOST_PASSWORD=votre_mot_de_passe_app
# DEFAULT_FROM_EMAIL=noreply@votresite.com

# SÉCURITÉ ADDITIONNELLE (PRODUCTION)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
